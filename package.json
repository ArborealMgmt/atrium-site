{
  "name": "terrapin-apartments",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.js",
    "postinstall": "svelte-kit sync",
    "dev": "vite dev",
    "predev": "node scripts/enforce-pnpm.js",
    "build": "vite build",
    "preview": "wrangler pages dev .svelte-kit/cloudflare",
    "deploy": "pnpm build && wrangler pages deploy .svelte-kit/cloudflare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "prepare": "husky"
  },
  "engines": {
    "node": "20.9.0",
    "pnpm": "9.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@internationalized/date": "^3.8.1",
    "@lucide/svelte": "^0.544.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@sveltejs/vite-plugin-svelte-inspector": "^5.0.1",
    "@tailwindcss/postcss": "^4.1.17",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^2.11.0",
    "clsx": "^2.1.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "set-cookie-parser": "^2.7.1",
    "svelte": "^5.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.6",
    "wrangler": "^4.58.0"
  },
  "dependencies": {
    "@axiomhq/js": "^1.3.1",
    "@axiomhq/logging": "^0.1.4",
    "@iconify/svelte": "^5.1.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.0",
    "dotenv": "^17.2.3",
    "mapbox-gl": "^3.16.0",
    "xml2js": "^0.6.2"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
